ame":"seed","type":"INT","widget":{"name":"seed"},"link":219},{"localized_name":"steps","name":"steps","type":"INT","widget":{"name":"steps"},"link":null},{"localized_name":"cfg","name":"cfg","type":"FLOAT","widget":{"name":"cfg"},"link":null},{"localized_name":"sampler_name","name":"sampler_name","type":"COMBO","widget":{"name":"sampler_name"},"link":null},{"localized_name":"scheduler","name":"scheduler","type":"COMBO","widget":{"name":"scheduler"},"link":null},{"localized_name":"denoise","name":"denoise","type":"FLOAT","widget":{"name":"denoise"},"link":null}],"outputs":[{"localized_name":"LATENT","name":"LATENT","type":"LATENT","links":[283]}],"properties":{"cnr_id":"comfy-core","ver":"0.10.0","Node name for S&R":"KSampler","ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":[957297162658210,"fixed",5,1,"euler","simple",0.5]},{"id":124,"type":"GetNode","pos":[3840,1160],"size":[220,60],"flags":{},"order":7,"mode":4,"inputs":[],"outputs":[{"name":"VAE","type":"VAE","links":[313]}],"title":"Get_VAE","properties":{"Node name for S&R":"GetNode","aux_id":"kijai/ComfyUI-KJNodes"},"widgets_values":["VAE"],"color":"#322","bgcolor":"#533"},{"id":47,"type":"ConditioningZeroOut","pos":[2360,1100],"size":[220,40],"flags":{},"order":21,"mode":0,"inputs":[{"localized_name":"conditioning","name":"conditioning","type":"CONDITIONING","link":115}],"outputs":[{"localized_name":"CONDITIONING","name":"CONDITIONING","type":"CONDITIONING","links":[116,210]}],"properties":{"cnr_id":"comfy-core","ver":"0.10.0","Node name for S&R":"ConditioningZeroOut","ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":[]},{"id":128,"type":"MarkdownNote","pos":[2100,-300],"size":[880,480],"flags":{},"order":8,"mode":0,"inputs":[],"outputs":[],"properties":{},"widgets_values":["# 🔥 Qwen3 4B Q8_0 GGUF — CLIP Benchmark (Z-Image Turbo)\n\n| Rank | Model              | Tier   | Rating        | Summary                                                                 |\n|------|-------------------|--------|---------------|-------------------------------------------------------------------------|\n| 🥇   | Lockout (Heretic) | S-Tier | 🔴🟠🟡🟡🟢 | Best overall: strongest material rendering, cinematic lighting, depth   |\n| 🥈   | Huihui            | A-Tier | 🔴🟠🟡🟡⚪ | Very clean and stable, great faces, slightly too balanced / soft        |\n| 🥉   | Josiefied         | B-Tier | 🔴🟠🟡⚪⚪ | Smooth and controlled, but lacks contrast and material realism          |\n| ❌   | BennyDaBall       | Trash  | 🔴⚪⚪⚪⚪ | Inconsistent, weak material response, unstable details                  |\n\n---\n\n## 🎯 Recommendation (Z-Image Turbo)\n\n- **Primary CLIP:** Lockout (Heretic)\n- **Secondary Option:** Huihui (for face stability)\n- **Avoid:** BennyDaBall (for this use case)\n\n---\n\n## ⚠️ Key Insight\n\nCLIP choice has a **major impact** on:\n- material realism (especially latex)\n- lighting behavior\n- overall image mood and depth\n\nThis matters **more than sampler tweaks** in most cases."],"color":"#223","bgcolor":"#335"},{"id":116,"type":"MarkdownNote","pos":[1120,-160],"size":[860,300],"flags":{},"order":9,"mode":0,"inputs":[],"outputs":[],"properties":{},"widgets_values":["# 📊 Z-Image Turbo – Resolution Guide (RTX 2070 | 8GB VRAM)\n\n| Resolution     | Quality        | VRAM Load       | Speed           | Stability       | Recommendation |\n|----------------|----------------|-----------------|-----------------|-----------------|----------------|\n| 704 × 1056     | 🔴🟠🟡⚪⚪ | 🔴⚪⚪⚪⚪ | 🔴🟠🟡🟡🟢 | 🔴🟠🟡🟡🟢 | Speed / testing |\n| 768 × 1152     | 🔴🟠🟡🟡⚪ | 🔴🟠🟡⚪⚪ | 🔴🟠🟡🟡⚪ | 🔴🟠🟡🟡🟢 | ⭐ **BEST DEFAULT** |\n| 832 × 1248     | 🔴🟠🟡🟡🟢 | 🔴🟠🟡🟡⚪ | 🔴🟠🟡⚪⚪ | 🔴🟠🟡🟡⚪ | ⭐ **Quality sweet spot** |\n| 896 × 1344     | 🔴🟠🟡🟡🟢 | 🔴🟠🟡🟡🟡 | 🔴🟠⚪⚪⚪ | 🔴🟠🟡⚪⚪ | Detail / high-end |\n| 944 × 1408     | 🔴🟠🟡🟡🟢 | 🔴🟠🟠⚪⚪ | 🔴⚪⚪⚪⚪ | 🔴🟠⚪⚪⚪ | Limit / testing only |\n\n---\n\n## 🧠 Interpretation\n\n### 🟢 Quality\n- Z-Image Turbo scales well up to ~832–896  \n- Beyond that: minimal real gain → mostly overhead  \n\n### 🟡 VRAM Behavior (8GB)\n- Up to **768×1152** = stable  \n- **832×1248** = usually stable  \n- **896+** depends heavily on:\n  - LoRAs  \n  - batch size  \n  - sampler  \n  - workflow complexity  \n\n### 🔴 Critical Range\n- **944×1408**\n  - can work  \n  - but:\n    - slow  \n    - VRAM spikes  \n    - unstable in complex workflows  \n\n---\n\n## 🎯 Clear Recommendation\n\n- **Default:** `768 × 1152`  \n- **Best quality without stress:** `832 × 1248`  \n- **Maximum reasonable:** `896 × 1344`  \n- **Above that:** only for controlled testing  \n\n---\n\n## ⚠️ Bonus (relevant for your setup)\n\nFor try-on workflows:\n\n- Input resize: **~832**  \n- Output:\n  - stable: `768 × 1152`  \n  - high quality: `832 × 1248`  \n\n→ helps prevent:\n- mask drift  \n- outfit artifacts  \n- unnecessary VRAM issues  "],"color":"#223","bgcolor":"#335"},{"id":133,"type":"MarkdownNote","pos":[3020,-420],"size":[840,440],"flags":{},"order":10,"mode":0,"inputs":[],"outputs":[],"properties":{},"widgets_values":["# Sampler and Scheduler Recommendations by Model Family\n\n> Rated on a visual scale: 🔴 poor → 🟢 optimal\n\n| Model Family | Sampler | Scheduler | Rating |\n|---|---|---|---|\n| **Z-Image Turbo** | dpmpp_sde | beta | 🔴🟠🟡🟡🟢 |\n|  | dpmpp_sde | ddim_uniform | 🔴🟠🟡🟡🟢 |\n|  | euler_ancestral | beta | 🔴🟠🟡🟡⚪ |\n|  | euler_ancestral | ddim_uniform | 🔴🟠🟡🟡⚪ |\n|  | dpmpp_sde | sgm_uniform | 🔴🟠🟡⚪⚪ |\n|  | euler_ancestral | sgm_uniform | 🔴🟠🟡⚪⚪ |\n|  | euler | beta | 🔴🟠⚪⚪⚪ |\n|  | euler | ddim_uniform | 🔴🟠⚪⚪⚪ |\n|  | euler | karras | 🔴⚪⚪⚪⚪ |\n| **Flux.2 Klein** | dpmpp_2m | sgm_uniform | 🔴🟠🟡🟡🟢 |\n|  | dpmpp_sde | sgm_uniform | 🔴🟠🟡🟡⚪ |\n|  | dpmpp_2m | beta | 🔴🟠🟡🟡⚪ |\n|  | euler | simple | 🔴🟠🟡⚪⚪ |\n|  | euler | beta | 🔴🟠🟡⚪⚪ |\n|  | euler | ddim_uniform | 🔴🟠⚪⚪⚪ |\n|  | euler_ancestral | sgm_uniform | 🔴🟠⚪⚪⚪ |\n|  | dpmpp_sde | beta | 🔴🟠⚪⚪⚪ |\n|  | euler | karras | 🔴⚪⚪⚪⚪ |\n| **Qwen (Diffusion)** | dpmpp_sde | beta | 🔴🟠🟡🟡🟢 |\n|  | dpmpp_2m | sgm_uniform | 🔴🟠🟡🟡🟢 |\n|  | dpmpp_sde | sgm_uniform | 🔴🟠🟡🟡⚪ |\n|  | dpmpp_2m | beta | 🔴🟠🟡🟡⚪ |\n|  | euler | simple | 🔴🟠🟡⚪⚪ |\n|  | euler | beta | 🔴🟠🟡⚪⚪ |\n|  | euler_ancestral | sgm_uniform | 🔴🟠🟡⚪⚪ |\n|  | euler | ddim_uniform | 🔴🟠⚪⚪⚪ |\n|  | euler | karras | 🔴⚪⚪⚪⚪ |"],"color":"#223","bgcolor":"#335"},{"id":81,"type":"UNETLoader","pos":[1040,700],"size":[320,100],"flags":{},"order":11,"mode":0,"inputs":[{"localized_name":"unet_name","name":"unet_name","type":"COMBO","widget":{"name":"unet_name"},"link":null},{"localized_name":"weight_dtype","name":"weight_dtype","type":"COMBO","widget":{"name":"weight_dtype"},"link":null}],"outputs":[{"localized_name":"MODEL","name":"MODEL","type":"MODEL","links":[303]}],"properties":{"cnr_id":"comfy-core","ver":"0.10.0","Node name for S&R":"UNETLoader","ue_properties":{"version":"7.0.1","widget_ue_connectable":{"unet_name":true,"weight_dtype":true}}},"widgets_values":["Z-Image Turbo\\jibMixZIT_v10.safetensors","default"],"color":"#223","bgcolor":"#335"},{"id":25,"type":"VAEDecode","pos":[3020,620],"size":[140,60],"flags":{"collapsed":false},"order":24,"mode":0,"inputs":[{"localized_name":"samples","name":"samples","type":"LATENT","link":36},{"localized_name":"vae","name":"vae","type":"VAE","link":314}],"outputs":[{"localized_name":"IMAGE","name":"IMAGE","type":"IMAGE","links":[319]}],"properties":{"cnr_id":"comfy-core","ver":"0.11.0","Node name for S&R":"VAEDecode","ue_properties":{"version":"7.0.1","widget_ue_connectable":{}}},"widgets_values":[]},{"id":95,"type":"easy loraStack","pos":[1040,1200],"size":[320,298],"flags":{},"order":12,"mode":0,"inputs":[{"localized_name":"optional_lora_stack","name":"optional_lora_stack","shape":7,"type":"LORA_STACK","link":null},{"localized_name":"toggle","name":"toggle","type":"BOOLEAN","widget":{"name":"toggle"},"link":null},{"localized_name":"mode","name":"mode","type":"COMBO","widget":{"name":"mode"},"link":null},{"localized_name":"num_loras","name":"num_loras","type":"INT","widget":{"name":"num_loras"},"link":null},{"localiz